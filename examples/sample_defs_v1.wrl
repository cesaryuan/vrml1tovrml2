#VRML V1.0 ascii

Separator {
  DEF SharedCoords Coordinate3 {
    point [
      0 0 0
      2 0 0
      0 2 0
      2 2 0
    ]
  }

  DEF SharedMat Material {
    diffuseColor 0.3 0.8 0.4
    ambientColor 0.1 0.2 0.1
  }

  Separator {
    USE SharedMat
    USE SharedCoords
    IndexedLineSet {
      coordIndex [ 0, 1, 3, 2, 0, -1 ]
    }
  }

  Translation {
    translation 0 0 2
  }

  Separator {
    USE SharedMat
    USE SharedCoords
    PointSet {
      startIndex 1
      numPoints 2
    }
  }
}
