#!/usr/bin/env bash
# Forward to the Rust CLI so Linux users get a native entrypoint.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "${HOME}/.cargo/env" ]]; then
  # Load Cargo into PATH for shells that have not sourced rustup yet.
  # shellcheck disable=SC1090
  . "${HOME}/.cargo/env"
fi

exec cargo run --release --quiet --manifest-path "${SCRIPT_DIR}/Cargo.toml" -- "$@"
